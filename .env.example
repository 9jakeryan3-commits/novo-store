# novo-store env (Vercel). Subscription-only model. Set these in the Vercel project's Environment Variables.

# --- Stripe (subscription checkout + webhook) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_SUB_ID=price_...            # monthly plan price id
STRIPE_PRICE_SUB_YEARLY_ID=price_...     # yearly plan price id
STRIPE_SUB_WEBHOOK_SECRET=whsec_...      # signing secret for THIS store's Stripe webhook (api/webhook-sub.js)
                                         # (separate from the control-plane's STRIPE_WEBHOOK_SECRET)

# --- Email (welcome email via Resend) ---
RESEND_API_KEY=re_...
# FROM_EMAIL: LEAVE UNSET. Code defaults to the Resend-verified domain (NoVo <orders@novo-aitrading.app>).
# Setting it to a non-verified address (e.g. a gmail) makes Resend 403 and SILENTLY kills all emails —
# this exact misconfig caused the 2026-06-25 launch outage. Only set if you've verified another domain.
# FROM_EMAIL=

# --- Site ---
SITE_URL=https://novo-aitrading.app      # the store's own URL (no trailing slash)
# SALES_PAUSED=1                         # set to "1" to hard-pause checkout (the kill switch)

# --- Legacy / optional (self-host era; vestigial under the hosted model) ---
# The store still ships api/reconcile-subs.js + license calls in webhook-sub.js that hit the old license
# server. They are no-ops for the hosted product (the control plane owns subscription state) and fail safe
# if these are unset. Only needed if you ever reactivate self-host license issuance.
# NOVO_LICENSE_SERVER_URL=https://...
# LICENSE_ADMIN_KEY=...
# CRON_SECRET=...                        # guards api/reconcile-subs (Vercel cron)
# CF_API_TOKEN=...                       # api/provision-tunnel (self-host Cloudflare tunnel provisioning)
# BLOB_READ_WRITE_TOKEN=...              # Vercel Blob (legacy buyer-zip hosting)
